# Accoustica environment
# Copy this file to .env.local for local development.

# Required by src/lib/app-params.js and @base44/sdk
VITE_BASE44_APP_ID=
VITE_BASE44_BACKEND_URL=

# Server-only Base44/KIE function env values. Do not prefix with VITE_.
SUNO_API_KEY=
KIE_API_KEY=
BASE44_APP_ID=
BASE44_FUNCTION_URL=
ACCOUSTICA_CALLBACK_SECRET=

# Server-only LLM provider env values. Do not prefix with VITE_.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openrouter/auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
LLM_PRIMARY_PROVIDER=openrouter
LLM_ENABLE_FALLBACK=true
ACCOUSTICA_APP_URL=

# Optional: enable Base44 legacy SDK import compatibility in vite.config.js
BASE44_LEGACY_SDK_IMPORTS=false

# Do not commit .env.local or real production values.
